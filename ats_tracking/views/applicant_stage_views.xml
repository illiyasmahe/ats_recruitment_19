<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Tree View -->
    <record id="view_applicant_stage_tree" model="ir.ui.view">
        <field name="name">ats.applicant.stage.tree</field>
        <field name="model">ats.applicant.stage</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_applicant_stage_form" model="ir.ui.view">
        <field name="name">ats.applicant.stage.form</field>
        <field name="model">ats.applicant.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="sequence"/>
                        <field name="active"/>
                        <field name="is_hired"/>
                        <field name="is_rejected"/>
                        <field name="is_readonly"/>
                    </group>

                    <group>
                        <field name="description"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_applicant_stage" model="ir.actions.act_window">
        <field name="name">Applicant Stages</field>
        <field name="res_model">ats.applicant.stage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_ats_root"
          name="ATS Recruitment"
              web_icon="ats_tracking,static/description/icon.png"
          sequence="10"/>

    <menuitem id="menu_ats_configuration"
              name="Configuration"
              parent="menu_ats_root"
              sequence="20"/>

    <menuitem id="menu_applicant_stage"
              name="Applicant Stages"
              parent="menu_ats_configuration"
              action="action_applicant_stage"
              sequence="10"/>

</odoo>