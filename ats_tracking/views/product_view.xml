<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="product_template_form_recruitment_service" model="ir.ui.view">
        <field name="name">product.template.form.recruitment.service</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <!-- Add field in General Information -->
            <div name="options" position='inside'>
                <span class="d-inline-flex">
                    <field name="is_recruitment_service"/>
                    <label for="is_recruitment_service"/>
                </span>
            </div>

        </field>
    </record>

    <record id="product_product_form_recruitment_service" model="ir.ui.view">
        <field name="name">product.product.form.recruitment.service</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-flex">
                    <field name="is_recruitment_service"/>
                    <label for="is_recruitment_service"/>
                </span>
            </xpath>

        </field>
    </record>

</odoo>