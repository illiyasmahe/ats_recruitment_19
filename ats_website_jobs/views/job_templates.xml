        <t t-call="website.layout">

            <!-- HERO -->
            <section class="career-hero text-white text-center">
                <div class="container">

                    <h1 class="fw-bold">
                        Complete Your Application
                    </h1>

                    <p class="lead">
                        Please confirm your details and upload your resume to finish your application.
                    </p>

                </div>
            </section>


            <!-- CONFIRM FORM -->
            <section class="py-5 bg-soft">

                <div class="container">

                    <div class="row justify-content-center">

                        <div class="col-lg-8">

                            <div class="card shadow-sm border-0">

                                <div class="card-body p-4">

                                    <!-- LINKEDIN IMAGE -->
                                    <t t-if="request.params.get('picture')">
                                        <div class="text-center mb-4">
                                            <img t-att-src="request.params.get('picture')"
                                                 style="width:140px;height:140px;border-radius:50%;object-fit:cover;box-shadow:0 4px 15px rgba(0,0,0,0.15);"/>
                                        </div>
                                    </t>

                                    <form action="/jobs/linkedin/confirm" method="post" enctype="multipart/form-data">

                                        <input type="hidden"
                                               name="job_id"
                                               t-att-value="request.params.get('job_id')"/>

                                        <input type="hidden"
                                               name="csrf_token"
                                               t-att-value="request.csrf_token()"/>

                                        <!-- NAME -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                Full Name
                                            </label>

                                            <input type="text"
                                                   name="name"
                                                   class="form-control"
                                                   t-att-value="request.params.get('name')"
                                                   readonly="readonly"/>

                                        </div>


                                        <!-- EMAIL -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                Email
                                            </label>

                                            <input type="email"
                                                   name="email"
                                                   class="form-control"
                                                   t-att-value="request.params.get('email')"
                                                   readonly="readonly"/>

                                            <div class="mt-2">

                                                <t t-if="request.params.get('email_verified')">
                                                    <span class="badge badge-verified">
                                                        <i class="fa fa-check-circle me-1"/>
                                                        Email Verified by LinkedIn
                                                    </span>
                                                </t>

                                            </div>

                                        </div>


                                        <!-- PHONE -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                Phone <span class="required">*</span>
                                            </label>

                                            <input type="text"
                                                   name="phone"
                                                   class="form-control"
                                                   placeholder="Enter phone number"
                                                   required="required"/>

                                        </div>


                                        <!-- ALT PHONE -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                Alternate Phone
                                            </label>

                                            <input type="text"
                                                   name="alt_phone"
                                                   class="form-control"
                                                   placeholder="Alternate phone"/>

                                        </div>


                                        <!-- LINKEDIN URL -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                LinkedIn Profile <span class="required">*</span>
                                            </label>

                                            <input type="url"
                                                   name="linkedin"
                                                   class="form-control"
                                                   required="required"
                                                   placeholder="https://www.linkedin.com/in/your-profile"/>

                                        </div>

                                        <div class="mb-4">

                                            <label class="form-label">
                                                Upload Resume <span class="required">*</span>
                                            </label>

                                            <input type="file"
                                                   name="resume"
                                                   class="form-control"
                                                   required="required"/>

                                        </div>


                                        <!-- COVER LETTER -->
                                        <div class="mb-4">

                                            <label class="form-label">
                                                Cover Letter
                                            </label>

                                            <textarea name="cover_letter"
                                                      class="form-control"
                                                      rows="5"
                                                      placeholder="Write your cover letter..."><t t-esc="request.params.get('cover_letter')"/></textarea>

                                        </div>


                                        <!-- CONFIRM BUTTON -->
                                        <button type="submit"
                                                class="btn btn-career w-100">

                                            Confirm Application

                                        </button>

                                    </form>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </section>


            <!-- STYLE (same as apply page) -->
            <style>

                .bg-soft{
                    background:#f5f7fb;
                }

                .career-hero{
                    background:#1e293b;
                    padding:70px 0;
                }
                .badge-verified{
                    background:#16a34a;
                    color:white;
                    font-size:13px;
                    padding:6px 12px;
                    border-radius:20px;
                }

                .required{
                    color:#dc3545;
                    font-weight:bold;
                    margin-left:2px;
                }

                .btn-career{
                    background:#1e293b;
                    color:white;
                    border-radius:8px;
                    font-weight:500;
                    padding:12px;
                }

                .btn-career:hover{
                    background:#0f172a;
                    color:white;
                }

            </style>

        </t>
        </template>



</odoo>