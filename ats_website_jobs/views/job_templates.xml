<odoo>

    <template id="job_list_page" name="Career Page">
        <t t-call="website.layout">

            <!-- HERO -->
            <section class="career-hero text-center text-white">
                <div class="container">

                    <h1 class="display-5 fw-bold">Careers at Our Company</h1>

                    <form action="/jobs" method="get" class="mt-4">
                        <div class="row justify-content-center">
                            <div class="col-md-6">

                                <div class="input-group">
                                    <input type="text"
                                           name="search"
                                           class="form-control form-control-lg"
                                           placeholder="Search job..."
                                           t-att-value="search"/>

                                    <button class="btn btn-career">
                                        <i class="fa fa-search"/>
                                    </button>
                                </div>

                            </div>
                        </div>
                    </form>

                </div>
            </section>


            <!-- JOB SECTION -->
            <section class="py-5 bg-soft">
                <div class="container">

                    <div class="row">

                        <!-- LEFT JOB LIST -->
                        <div class="col-lg-7">

                            <t t-foreach="jobs" t-as="job">

                                <div class="card job-card mb-3 shadow-sm job-select"
                                     t-att-data-id="job.id">

                                    <div class="card-body">

                                        <h5 class="fw-bold text-primary">
                                            <t t-esc="job.name"/>
                                        </h5>

                                        <p class="text-muted">
                                            <i class="fa fa-building me-2"/>
                                            <t t-esc="job.project_id.name"/>
                                        </p>

                                        <div class="small text-muted">
                                            <div>
                                                Open:
                                                <t t-esc="job.opened_positions"/>
                                            </div>

                                            <div>
                                                Closed:
                                                <t t-esc="job.closed_positions"/>
                                            </div>
                                        </div>


                                        <!-- MOBILE ACTION BUTTONS -->
                                        <div class="mt-3 d-grid gap-2 d-lg-none">

                                            <a class="btn btn-sm btn-career"
                                               t-att-href="'/jobs/' + str(job.id)">
                                                View Details
                                            </a>

                                            <a class="btn btn-sm btn-outline-dark"
                                               t-att-href="'/jobs/apply/' + str(job.id)">
                                                Apply
                                            </a>

                                        </div>

                                    </div>

                                </div>

                            </t>

                        </div>


                        <!-- RIGHT DETAIL PANEL (DESKTOP ONLY) -->
                        <div class="col-lg-5 d-none d-lg-block">

                            <div id="job-details-panel"
                                 class="job-detail-panel shadow-sm p-4">

                                <div class="text-center text-muted py-5">
                                    <h5>No Job Selected</h5>
                                    <p>Select a job from the list</p>
                                </div>

                            </div>

                        </div>

                    </div>


                    <!-- PAGINATION -->
                    <div class="mt-5 d-flex justify-content-center">

                        <t t-call="website.pager">
                            <t t-set="pager" t-value="pager"/>
                            <t t-set="keep" t-value="keep"/>
                        </t>

                    </div>

                </div>
            </section>


            <!-- SCRIPT -->
            <script>
                document.addEventListener("DOMContentLoaded", function () {

                    const jobCards = document.querySelectorAll(".job-select");
                    const panel = document.getElementById("job-details-panel");

                    function loadJob(jobId) {
                        fetch("/jobs/sidebar/" + jobId)
                            .then(response => response.text())
                            .then(html => {
                                panel.innerHTML = html;
                            });
                    }

                    jobCards.forEach(function(card) {

                        card.addEventListener("click", function() {

                            /* Disable sidebar on mobile */
                            if (window.innerWidth &lt; 992) {
                                return;
                            }

                            const jobId = this.dataset.id;

                            /* Remove active class */
                            jobCards.forEach(c => c.classList.remove("active-job"));

                            /* Add active class */
                            this.classList.add("active-job");

                            loadJob(jobId);

                        });

                    });


                    /* Auto select first job on desktop */
                    if (jobCards.length > 0 &amp;&amp; window.innerWidth >= 992) {

                        const firstJob = jobCards[0];

                        firstJob.classList.add("active-job");

                        loadJob(firstJob.dataset.id);

                    }

                });
            </script>


            <!-- STYLES -->
            <style>

                .bg-soft {
                    background: #f5f7fb;
                }

                .career-hero {
                    background: #1e293b;
                    padding: 80px 0;
                }

                .job-card {
                    border-radius: 12px;
                    cursor: pointer;
                    transition: all 0.25s;
                }

                .job-card:hover {
                    transform: translateY(-4px);
                    box-shadow: 0 10px 20px rgba(0,0,0,0.08);
                }

                .job-card.active-job {
                    border-left: 5px solid #1e293b;
                    background: #f8fafc;
                }

                .job-detail-panel {
                    background: white;
                    border-radius: 14px;
                    height: 600px;
                    overflow-y: auto;
                    position: sticky;
                    top: 40px;
                }

                .btn-career {
                    background: #1e293b;
                    color: white;
                    border-radius: 8px;
                }

                .btn-career:hover {
                    background: #0f172a;
                    color: white;
                }

            </style>

        </t>
    </template>



    <!-- RIGHT PANEL TEMPLATE -->
    <template id="job_detail_sidebar">

        <h4 class="fw-bold mb-3">
            <t t-esc="job.name"/>
        </h4>

        <div class="mt-4 d-grid gap-2">

            <a class="btn btn-career"
               t-att-href="'/jobs/' + str(job.id)">
                View Details
            </a>

            <a class="btn btn-outline-dark"
               t-att-href="'/jobs/apply/' + str(job.id)">
                Apply
            </a>

        </div>

        <p class="text-muted mt-3">
            <i class="fa fa-building me-2"/>
            <t t-esc="job.project_id.name"/>
        </p>

        <hr/>

        <p>
            <strong>Open Positions:</strong>
            <t t-esc="job.opened_positions"/>
        </p>

        <p>
            <strong>Closed Positions:</strong>
            <t t-esc="job.closed_positions"/>
        </p>

        <p>
            <strong>Status:</strong>
            <t t-esc="job.position_state.upper()"/>
        </p>

        <p>
            <strong>Description:</strong>
        </p>

        <t t-if="job.description">
            <t t-raw="job.description"/>
        </t>

        <t t-if="not job.description">
            <p>No description available.</p>
        </t>

    </template>

    <template id="job_detail_page" name="Job Detail Page">
        <t t-call="website.layout">

            <!-- HERO -->
            <section class="career-hero text-white text-center">
                <div class="container">

                    <h1 class="display-5 fw-bold">
                        <t t-esc="job.name"/>
                    </h1>

                    <p class="lead mt-3">
                        <i class="fa fa-building me-2"/>
                        <t t-esc="job.project_id.name"/>
                    </p>

                </div>
            </section>


            <!-- JOB DETAILS -->
            <section class="py-5 bg-soft">
                <div class="container">

                    <div class="row">

                        <!-- LEFT CONTENT -->
