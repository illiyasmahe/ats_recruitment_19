                            <div class="card border-0 shadow-sm mb-4">

                                <div class="card-body">

                                    <h4 class="fw-bold mb-3">
                                        Job Description
                                    </h4>

                                    <div class="text-muted">

                                        <t t-if="job.description">
                                            <t t-raw="job.description"/>
                                        </t>

                                        <t t-if="not job.description">
                                            <p>No description available.</p>
                                        </t>

                                    </div>

                                </div>

                            </div>

                        </div>


                        <!-- RIGHT SIDEBAR -->
                        <div class="col-lg-4">

                            <div class="card border-0 shadow-sm">

                                <div class="card-body">

                                    <h5 class="fw-bold mb-4">
                                        Job Overview
                                    </h5>


                                    <!-- Company -->
                                    <div class="mb-3">
                                        <i class="fa fa-building text-primary me-2"/>
                                        <strong>Company:</strong>
                                        <t t-esc="job.project_id.name"/>
                                    </div>


                                    <!-- Open -->
                                    <div class="mb-3">
                                        <i class="fa fa-users text-success me-2"/>
                                        <strong>Open Positions:</strong>
                                        <t t-esc="job.opened_positions"/>
                                    </div>


                                    <!-- Closed -->
                                    <div class="mb-3">
                                        <i class="fa fa-check-circle text-secondary me-2"/>
                                        <strong>Closed Positions:</strong>
                                        <t t-esc="job.closed_positions"/>
                                    </div>


                                    <!-- Status -->
                                    <div class="mb-4">

                                        <strong>Status:</strong>

                                        <span t-att-class="
                                            'badge rounded-pill ms-2 px-3 py-2 ' +
                                            ('badge-open' if job.position_state == 'open'
                                             else 'badge-paused' if job.position_state == 'paused'
                                             else 'badge-closed')
                                        ">
                                            <t t-esc="job.position_state.upper()"/>
                                        </span>

                                    </div>


                                    <!-- APPLY BUTTON -->
                                    <a class="btn btn-career w-100"
                                       t-att-href="'/jobs/apply/' + str(job.id)">
                                        Apply for this Job
                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>
            </section>


            <!-- STYLE -->
            <style>

                .bg-soft{
                    background:#f5f7fb;
                }

                .career-hero{
                    background:#1e293b;
                    padding:80px 0;
                }

                .btn-career{
                    background:#1e293b;
                    color:white;
                    border-radius:8px;
                    font-weight:500;
                    padding:10px;
                }

                .btn-career:hover{
                    background:#0f172a;
                    color:white;
                }

                .badge-open{
                    background:#16a34a;
                    color:white;
                }

                .badge-paused{
                    background:#f59e0b;
                    color:white;
                }

                .badge-closed{
                    background:#6b7280;
                    color:white;
                }

            </style>

        </t>
    </template>

    <template id="job_apply_page" name="Job Apply Page">
        <t t-call="website.layout">

            <!-- HERO -->
            <section class="career-hero text-white text-center">
                <div class="container">

                    <h1 class="fw-bold">
                        Apply for
                        <t t-esc="job.name"/>
                    </h1>

                    <p class="lead">
                        <i class="fa fa-building me-2"/>
                        <t t-esc="job.project_id.name"/>
                    </p>

                </div>
            </section>


            <!-- APPLY FORM -->
            <section class="py-5 bg-soft">

                <div class="container">

                    <div class="row justify-content-center">

                        <div class="col-lg-8">

                            <div class="card shadow-sm border-0">

                                <div class="card-body p-4">

                                    <h4 class="fw-bold mb-4">
                                        Submit Your Application
                                    </h4>

                                    <t t-if="error">
                                        <div class="alert alert-danger">
                                            <t t-esc="error"/>
                                        </div>
                                    </t>


                                    <form action="/jobs/apply/submit"
                                          id="job_apply_form"
                                          method="post"
                                          enctype="multipart/form-data">

                                        <input type="hidden"
                                               name="csrf_token"
                                               t-att-value="request.csrf_token()"/>

                                        <input type="hidden"
                                               name="job_id"
                                               t-att-value="job.id"/>
                                        <input type="hidden" name="linkedin_picture"/>
                                        <input type="hidden" name="linkedin_sub"/>
                                        <input type="hidden" name="linkedin_email_verified"/>


                                        <!-- NAME -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                Full Name <span class="required">*</span>
                                            </label>

                                            <input type="text"
                                                   name="name"
                                                   class="form-control"
                                                   placeholder="Full Name"
                                                   required="required"/>

                                        </div>


                                        <!-- EMAIL -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                Email <span class="required">*</span>
                                            </label>

                                            <input type="email"
                                                   name="email"
                                                   class="form-control"
                                                   placeholder="Email"
                                                   required="required"/>

                                        </div>


                                        <!-- PHONE -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                Phone <span class="required">*</span>
                                            </label>

                                            <input type="text"
                                                   name="phone"
                                                   required="required"
                                                   pattern="^\+?[0-9\s\-]{7,15}$"
                                                   placeholder="Phone"
                                                   class="form-control"/>

                                        </div>

                                        <div class="mb-3">

                                            <label class="form-label">
                                                Alternate Phone <span class="required">*</span>
                                            </label>

                                            <input type="text"
                                                   name="alt_phone"
                                                   required="required"
                                                   pattern="^\+?[0-9\s\-]{7,15}$"
                                                   placeholder="Alternate Phone"
                                                   class="form-control"/>

                                        </div>


                                        <!-- RESUME -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                Upload Resume <span class="required">*</span>
                                            </label>

                                            <input type="file"
                                                   name="resume"
                                                   class="form-control"
                                                   required="required"/>

                                        </div>

                                        <!-- LINKEDIN -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                LinkedIn Profile
                                            </label>

                                            <input type="url"
                                                   name="linkedin"
                                                   class="form-control"
                                                   placeholder="https://www.linkedin.com/in/your-profile"
                                                   pattern="https?://(www\.)?linkedin\.com/.*"
                                                   title="Enter a valid LinkedIn profile URL"/>

                                        </div>


                                        <!-- COVER LETTER -->
                                        <div class="mb-4">

                                            <label class="form-label">
                                                Cover Letter
                                            </label>

                                            <textarea name="cover_letter"
                                                      class="form-control"
                                                      placeholder="Cover Letter"
                                                      rows="5"/>

                                        </div>


                                        <!-- SUBMIT -->
                                        <button type="submit"
                                                class="btn btn-career w-100">

                                            Submit Application

                                        </button>
<!--                                        <div t-if="signup_with_linkedin" class="mt-3 linkedin-login-btn w-100"-->
<!--                                             style="display: flex; align-items: center; justify-content: center; font-weight: 600; border-radius: 4px; cursor: pointer; width: max-content; transition: background-color 0.3s;"-->
<!--                                             >-->
<!--                                            <img src="/ats_website_jobs/static/src/img/linkdin.png"-->
<!--                                                 alt="LinkedIn" onmouseover="this.style.backgroundColor='#E6F0FA'"-->
<!--                                                    onmouseout="this.style.backgroundColor='transparent'"-->
<!--                                                 />-->
<!--                                        </div>-->

                                    </form>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </section>


            <!-- STYLE -->
            <style>
                .bg-soft{
                    background:#f5f7fb;
                }

                .career-hero{
                    background:#1e293b;
                    padding:70px 0;
                }
                .required{
                    color:#dc3545;
                    font-weight:bold;
                    margin-left:2px;
                }

                .btn-career{
                    background:#1e293b;
                    color:white;
                    border-radius:8px;
                    font-weight:500;
                    padding:12px;
                }

                .btn-career:hover{
                    background:#0f172a;
                    color:white;
                }

            </style>
            <script>
                document.querySelector('.linkedin-login-btn').addEventListener('click', async function() {
                    const width = 600;
                    const height = 600;
                    const left = (screen.width - width) / 2;
                    const top = (screen.height - height) / 2;

                    // Fetch the URL from Odoo route
                    const response = await fetch('/linkedin/signup');
                    const url = await response.text();  // URL returned as plain text

                    const popup = window.open(
                        url,
                        'LinkedIn Login',
                        `width=${width},height=${height},top=${top},left=${left}`
                    );

                    // Listen for message from popup
                    window.addEventListener('message', function(event) {
                        if (event.origin !== window.location.origin) return;

                        const profile = event.data.linkedinProfile;
                        if(profile){
                            const form = document.getElementById('job_apply_form');
                            if(profile.name) document.querySelector('input[name="name"]').value = profile.name;
                            if(profile.email) document.querySelector('input[name="email"]').value = profile.email;
                            if(profile.picture) document.querySelector('input[name="linkedin_picture"]').value = profile.picture;
                            if(profile.sub) document.querySelector('input[name="linkedin_sub"]').value = profile.sub;
                            if(profile.email_verified) document.querySelector('input[name="linkedin_email_verified"]').value = profile.email_verified;
                            form.submit();
                        }
                    });
                });
                </script>

        </t>
    </template>


