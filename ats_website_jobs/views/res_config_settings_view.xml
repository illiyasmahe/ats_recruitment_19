<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_view_form_linkedin_block" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.linkedin.block</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Insert a new block under the sheet -->
            <xpath expr="//block[@id='website_info_settings']" position="after">
                <block title="Linkedin" id="website_linkedin_settings">
                        <setting string="Client ID"
                                 >
                            <field name="linkedin_client_id"/>
                        </setting>
                        <setting string="Client Secret">
                            <field name="linkedin_client_secret"/>
                        </setting>
                        <setting string="Redirect URL">
                            <field name="linkedin_redirect_uri" placeholder="https://yourdomain.com/linkedin/callback"/>
                        </setting>
<!--                        <setting string="Signup With Linkedin">-->
<!--                            <field name="signup_with_linkedin"/>-->
<!--                        </setting>-->
                        <setting string="Access Token">
                            <field name="linkedin_access_token" readonly="1"/>
                        </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>